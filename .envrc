# shellcheck shell=bash
use flake
layout node

# No automatic dotenv loading. `dotenv_if_exists .env`/`.env.local` (the `layout
# node` template default) would export any local secret files into EVERY command
# run in this repo — package scripts, git hooks, dependency postinstalls — which
# is a token-leak surface. Repo-local secrets go through `.envrc.private` below
# (gitignored, opt-in), not auto-loaded dotenv files.
source_env_if_exists .envrc.private
