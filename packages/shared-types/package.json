{
	"name": "@0xbigboss/rn-driver-shared-types",
	"version": "0.1.0",
	"description": "Shared types for rn-playwright-driver packages",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"scripts": {
		"build": "echo 'Types only - no build needed'",
		"clean": "echo 'Types only - no build artifacts'",
		"lint": "biome check .",
