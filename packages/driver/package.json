{
  "name": "@unrulysystems/rn-playwright-driver",
  "version": "0.5.0",
  "description": "Playwright-compatible E2E test driver for React Native",
  "keywords": [
    "automation",
    "cdp",
    "e2e",
    "playwright",
    "react-native",
    "testing"
  ],
  "license": "MIT",
  "author": "0xbigboss",
  "repository": {
    "type": "git",
    "url": "https://github.com/unrulysystems/rn-playwright-driver",
    "directory": "packages/driver"
  },
  "bin": {
    "rn-inspect": "./bin/inspect.ts"
  },
  "files": [
    "bin",
    "dist",
    "harness",
    "!harness/**/*.test.ts",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./harness": {
      "types": "./harness/index.ts",
      "import": "./harness/index.ts",
      "require": "./harness/index.ts"
    },
    "./harness/dev": {
      "types": "./harness/dev.ts",
      "import": "./harness/dev.ts",
      "require": "./harness/dev.ts"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "import": "./dist/test.mjs",
      "require": "./dist/test.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "knip": "knip",
    "cpd": "jscpd ."
  },
  "dependencies": {
    "@unrulysystems/rn-driver-shared-types": "^0.1.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "^7.0.0-dev.20251227.1",
    "jscpd": "^4.0.5",
    "knip": "^5.78.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0",
    "react-native": ">=0.70.0",
    "react-native-safe-area-context": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-safe-area-context": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
