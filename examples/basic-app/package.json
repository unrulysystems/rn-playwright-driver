{
  "name": "examples-basic-app",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsgo --noEmit",
    "knip": "knip",
    "cpd": "jscpd .",
    "test:e2e": "playwright test",
    "test:e2e:android:dual": "bash scripts/e2e-android-dual.sh",
    "test:e2e:android:cli": "RN_TOUCH_BACKEND=cli playwright test e2e/integration/counter.spec.ts e2e/primitives/touch-backend.spec.ts",
    "test:e2e:android:instrumentation": "RN_TOUCH_BACKEND=instrumentation playwright test e2e/integration/counter.spec.ts e2e/primitives/touch-backend.spec.ts",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@unrulysystems/rn-driver-lifecycle": "workspace:*",
    "@unrulysystems/rn-driver-screenshot": "workspace:*",
    "@unrulysystems/rn-driver-touch": "workspace:*",
    "@unrulysystems/rn-driver-view-tree": "workspace:*",
    "@unrulysystems/rn-playwright-driver": "workspace:*",
    "@unrulysystems/rn-playwright-driver-instrumentation-companion": "workspace:*",
    "expo": "~54.0.30",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.9.3",
    "@types/react": "~19.1.0",
    "@typescript/native-preview": "^7.0.0-dev.20251227.1",
    "jscpd": "^4.0.5",
    "knip": "^5.78.0",
    "lefthook": "^2.0.13",
    "typescript": "~5.9.2"
  }
}
