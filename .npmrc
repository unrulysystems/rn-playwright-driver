# The @unrulysystems scope is published to (and installed from) the
# unrulysystems org's GitHub Packages registry. Auth uses a GitHub token with
# `read:packages` (install) / `write:packages` (publish) via the NODE_AUTH_TOKEN
# env var — never hardcode the token here. Locally: `NODE_AUTH_TOKEN=$(gh auth token)`.
@unrulysystems:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
