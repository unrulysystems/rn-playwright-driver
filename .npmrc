# Flat, npm-style node_modules layout. Deterministic + React Native-safe:
# RN's native autolinking (CocoaPods/Gradle) and the long tail of packages with
# hardcoded ../../node_modules paths expect a hoisted tree, not nub/pnpm's
# default isolated virtual store. Pinned here so layout never depends on nub's
# incumbent detection (which would flip to isolated once pnpm-lock.yaml exists).
node-linker=hoisted
